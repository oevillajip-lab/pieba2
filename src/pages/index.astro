      .nos-grid { grid-template-columns: 1fr; padding: 0 1.2rem; gap: 1.5rem; max-width: 100%; }
      .nos-visual { display: none; }
      .section-title { font-size: clamp(1.5rem, 7vw, 2.2rem); line-height: 1.15; }
