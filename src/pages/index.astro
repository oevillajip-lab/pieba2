      .nos-list li span { font-size: .84rem; }

      .cultos-wrap { width: 100%; max-width: 100%; padding: 0 1.2rem; }
      .culto-cards { grid-template-columns: 1fr; gap: .85rem; margin-top: 1.5rem; }
      .culto-card { padding: 1.2rem 1rem; }
      .culto-hora { font-size: 1.65rem; }
      .video-library { margin-top: 1.2rem; padding: 1rem; }
      .video-library-head { align-items: stretch; }
      .video-library-title { font-size: 1rem; }
      .video-controls { width: 100%; justify-content: flex-start; }
      .video-filter-chips { gap: .45rem; }
      .video-chip { padding: .5rem .7rem; font-size: .62rem; }
      .video-month-wrap { width: 100%; }
      .video-month-select { width: 100%; min-width: 0; }
      .video-feature { grid-template-columns: 1fr; }
      .video-feature-media, .video-feature-placeholder { min-height: 220px; }
      .video-feature-title { font-size: 1.05rem; }
      .video-feature-actions { padding-top: .95rem; }
      .video-btn { width: 100%; }
      .video-strip { grid-template-columns: 1fr; }

      .envivo-wrap { width: 100%; max-width: 100%; padding: 0 1.2rem; }
      .stream-box { margin-top: 1.2rem; max-height: none; min-height: 200px; }

      /* Galería mobile */
      .galeria-wrap { width: 100%; max-width: 100%; padding: 0 1.2rem; }
      .album-grid { grid-template-columns: 1fr 1fr; gap: .85rem; margin-top: 1.5rem; }
      .lightbox-grid { grid-template-columns: repeat(2,1fr); padding: 1rem; gap: 2px; }
      .lightbox-header { padding: 1rem 1.1rem; }
      .lightbox-title { font-size: .95rem; }

      /* Avisos mobile */
      .avisos-wrap { width: 100%; max-width: 100%; padding: 0 1.2rem; }
      .aviso-list { margin-top: 1.5rem; gap: .7rem; }
      .aviso-card { padding: 1rem 1.1rem; gap: 1rem; }
      .aviso-titulo { font-size: .88rem; }
      .aviso-texto { font-size: .8rem; }

      /* Eventos mobile */
      .eventos-wrap { width: 100%; max-width: 100%; padding: 0 1.2rem; }
      .evento-grid { grid-template-columns: 1fr; gap: .85rem; margin-top: 1.5rem; }
      .evento-card { }

      /* Blog mobile */
      .blog-wrap { width: 100%; max-width: 100%; padding: 0 1.2rem; }
      .blog-grid { grid-template-columns: 1fr; gap: .85rem; margin-top: 1.5rem; }
      .blog-cover { aspect-ratio: 16/9; }
      .blog-side { gap: .85rem; }
      .blog-card-body { padding: 1rem 1.1rem 1.2rem; }

      .cont-grid { grid-template-columns: 1fr; padding: 0 1.2rem; gap: 1.5rem; max-width: 100%; }
      .cont-map { min-height: 220px; }
      .cont-items { gap: 1.1rem; }

      .ofr-wrap { width: 100%; max-width: 100%; padding: 0 1.2rem; }
      .ofr-cards { grid-template-columns: 1fr; gap: .9rem; margin-top: 1.4rem; }
      .ofr-card { padding: 1.2rem 1rem; }
    }

    @media (max-width: 480px) {
      .hero-name { font-size: clamp(1rem, 7.5vw, 1.5rem); }
      .section-title { font-size: clamp(1.3rem, 8vw, 1.9rem); }
      .album-grid { grid-template-columns: 1fr 1fr; gap: .6rem; }
      .album-name { font-size: .78rem; }
      .blog-titulo { font-size: .88rem; }
      .evento-titulo { font-size: .9rem; }
    }
