<script>
/* ── CANVAS STARS ── */
const canvas = document.getElementById('starCanvas');
const ctx = canvas.getContext('2d');
function resize() { canvas.width = canvas.offsetWidth; canvas.height = canvas.offsetHeight; }
resize();
window.addEventListener('resize', resize);
const stars = Array.from({ length: 140 }, () => ({
  x: Math.random(), y: Math.random(),
  r: Math.random() * 1.4 + 0.25,
  vy: Math.random() * 0.00012 + 0.00004,
  phase: Math.random() * Math.PI * 2,
  base: Math.random() * 0.55 + 0.1
}));
(function loop() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  stars.forEach(s => {
    s.phase += 0.018;
    const a = s.base * (0.55 + 0.45 * Math.sin(s.phase));
    ctx.beginPath();
    ctx.arc(s.x * canvas.width, s.y * canvas.height, s.r, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(201,169,110,${a})`;
    ctx.fill();
    s.y -= s.vy;
    if (s.y < 0) { s.y = 1.02; s.x = Math.random(); }
  });
  requestAnimationFrame(loop);
})();

/* ── NAV / SCROLL ── */
const wrap = document.getElementById('scrollWrap');
const topnav = document.getElementById('topnav');
const ham = document.getElementById('ham');
const mobileNav = document.getElementById('mobileNav');

const dots = [...document.querySelectorAll('.dot')];
const navLinks = [...document.querySelectorAll('.nav-links a[data-section]')];
const mobileNavLinks = [...document.querySelectorAll('.mobile-nav a[data-section]')];
const allNavLinks = [...navLinks, ...mobileNavLinks];
const sections = [...document.querySelectorAll('.page')];
const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

function getTargetTop(target) {
  const wrapRect = wrap.getBoundingClientRect();
  const targetRect = target.getBoundingClientRect();
  return wrap.scrollTop + (targetRect.top - wrapRect.top);
}

function openNav() {
  mobileNav.classList.add('open');
  ham.classList.add('open');
  ham.setAttribute('aria-expanded', 'true');
}

function closeNav() {
  mobileNav.classList.remove('open');
  ham.classList.remove('open');
  ham.setAttribute('aria-expanded', 'false');
}

function toggleNav(event) {
  event.preventDefault();
  event.stopPropagation();

  if (mobileNav.classList.contains('open')) {
    closeNav();
  } else {
    openNav();
  }
}

function setActive(id) {
  dots.forEach((dot) => {
    dot.classList.toggle('active', dot.dataset.target === id);
  });

  allNavLinks.forEach((link) => {
    const isActive = link.dataset.section === id;
    link.classList.toggle('active', isActive);

    if (isActive) {
      link.setAttribute('aria-current', 'page');
    } else {
      link.removeAttribute('aria-current');
    }
  });
}

function goTo(id) {
  const target = document.getElementById(id);
  if (!target || !wrap) return;

  closeNav();
  setActive(id);

  wrap.scrollTo({
    top: getTargetTop(target),
    behavior: prefersReducedMotion ? 'auto' : 'smooth'
  });

  if (history.replaceState) {
    history.replaceState(null, '', `#${id}`);
  }
}

ham.addEventListener('click', toggleNav);

document.addEventListener('click', (event) => {
  const trigger = event.target.closest('[data-target]');

  if (trigger) {
    event.preventDefault();
    const id = trigger.dataset.target;
    if (id) goTo(id);
    return;
  }

  if (
    mobileNav.classList.contains('open') &&
    !mobileNav.contains(event.target) &&
    !ham.contains(event.target)
  ) {
    closeNav();
  }
});

wrap.addEventListener('scroll', () => {
  topnav.classList.toggle('scrolled', wrap.scrollTop > 60);
});

const io = new IntersectionObserver((entries) => {
  entries.forEach((entry) => {
    if (entry.isIntersecting) {
      setActive(entry.target.id);
      entry.target.querySelectorAll('.reveal').forEach((el) => {
        el.classList.add('visible');
      });
    }
  });
}, {
  root: wrap,
  threshold: 0.45
});

sections.forEach((section) => io.observe(section));
document.querySelectorAll('#inicio .reveal').forEach((el) => el.classList.add('visible'));

if (location.hash) {
  const initialId = location.hash.replace('#', '');
  const initialTarget = document.getElementById(initialId);
  if (initialTarget) {
    requestAnimationFrame(() => goTo(initialId));
  }
}

/* ── LIGHTBOX ── */
function openAlbum(name, date, photoCount) {
  document.getElementById('lbTitle').textContent = name;
  document.getElementById('lbDate').textContent = date;
  const grid = document.getElementById('lbGrid');
  grid.innerHTML = '';

  if (photoCount === 0) {
    grid.innerHTML = `
      <div class="lightbox-empty">
        <p>Este álbum aún no tiene fotos.</p>
        <p style="margin-top:.5rem;font-size:.75rem;">Cuando integres Sanity CMS, las fotos aparecerán aquí automáticamente.</p>
        <div class="lb-upload-hint">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          Agregar fotos desde el panel CMS
        </div>
      </div>`;
  } else {
    for (let i = 0; i < photoCount; i++) {
      grid.innerHTML += `<div class="lightbox-photo"><div class="lightbox-photo-ph"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div></div>`;
    }
  }

  document.getElementById('lightbox').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeLightbox() {
  document.getElementById('lightbox').classList.remove('open');
  document.body.style.overflow = '';
}

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') closeLightbox();
});
</script>

<script>
/* ── YOUTUBE ── */
const YT_API_KEY    = 'AIzaSyAgz1KXOuS4q-uxNKL9GJdRQJ4P1jGrDG4';
const YT_CHANNEL_ID = 'UCcijrVl3zWSXSuzP3nQI32A';
const YT_BASE       = 'https://www.googleapis.com/youtube/v3';
const ytOK = () => Boolean(YT_API_KEY && YT_CHANNEL_ID);
const qs = s => document.querySelector(s);
const videoState = {
  all: [],
  filtered: [],
  selectedId: null,
  type: 'all',
  month: 'all'
};

async function ytFetch(path, params = {}) {
  const url = new URL(`${YT_BASE}/${path}`);
  Object.entries({ ...params, key: YT_API_KEY }).forEach(([k, v]) => {
    if (v !== undefined && v !== null && v !== '') url.searchParams.set(k, v);
  });
  const res = await fetch(url);
  const data = await res.json();
  if (!res.ok) throw new Error(data.error?.message || 'Error YouTube');
  return data;
}

function fmtDate(iso) {
  return new Date(iso).toLocaleDateString('es-PY', { day: 'numeric', month: 'long', year: 'numeric' });
}
function fmtDateTime(iso) {
  return new Date(iso).toLocaleString('es-PY', { weekday: 'long', day: 'numeric', month: 'long', hour: '2-digit', minute: '2-digit' });
}
function escapeHtml(str = '') {
  return str.replace(/[&<>"']/g, (m) => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;', "'":'&#39;' }[m]));
}
function videoUrl(videoId) {
  return `https://www.youtube.com/watch?v=${videoId}`;
}
function closeSermonPlayer() {
  // kept for compatibility with older markup if it exists
  const w = document.getElementById('sermonPlayerWrap');
  const f = document.getElementById('sermonPlayer');
  if (f) f.src = '';
  if (w) w.style.display = 'none';
}

async function getUploadsPlaylistId() {
  const data = await ytFetch('channels', { part: 'contentDetails', id: YT_CHANNEL_ID });
  return data.items?.[0]?.contentDetails?.relatedPlaylists?.uploads || null;
}

function normalizeText(str = '') {
  return String(str)
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[^\w\s]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
}

function classifyVideo(video) {
  const text = normalizeText(`${video.title} ${video.description || ''}`);

  if (/(aviso|anuncio|comunicado|agenda|informativo|novedades)/.test(text)) return 'Avisos';
  if (/(debate|panel|conversatorio|mesa redonda|dialogo|di[aá]logo)/.test(text)) return 'Debates';
  if (/(charla|conferencia|seminario|taller|entrevista|capacitacion|capacitaci[oó]n)/.test(text)) return 'Charlas';
  if (/(estudio biblico|estudio b[ií]blico|discipulado|devocional|escuela dominical|lectura b[ií]blica)/.test(text)) return 'Estudios';
  if (/(culto|predica|predicacion|predicación|sermon|serm[oó]n|mensaje|adoracion|adoración|domingo|miercoles|miércoles)/.test(text)) return 'Cultos';
  return 'Otros';
}

function toVideoItem(v) {
  if (!v) return null;
  const item = {
    videoId: v.id,
    title: v.snippet?.title || '',
    description: v.snippet?.description || '',
    thumb: v.snippet?.thumbnails?.high?.url || v.snippet?.thumbnails?.medium?.url || v.snippet?.thumbnails?.default?.url,
    publishedAt: v.snippet?.publishedAt || null,
    scheduledStartTime: v.liveStreamingDetails?.scheduledStartTime || null,
    actualStartTime: v.liveStreamingDetails?.actualStartTime || null,
    embeddable: v.status?.embeddable !== false,
    privacyStatus: v.status?.privacyStatus || 'public'
  };
  item.category = classifyVideo(item);
  item.monthKey = item.publishedAt ? item.publishedAt.slice(0, 7) : 'unknown';
  item.monthLabel = item.publishedAt
    ? new Date(`${item.monthKey}-01T00:00:00`).toLocaleDateString('es-PY', { month: 'long', year: 'numeric' })
    : 'Sin fecha';
  return item;
}

async function getVideoById(videoId) {
  if (!videoId) return null;
  const data = await ytFetch('videos', { part: 'snippet,status,liveStreamingDetails', id: videoId });
  return toVideoItem(data.items?.[0]);
}

async function getRecentUploads(limit = 24) {
  const uploadsId = await getUploadsPlaylistId();
  if (!uploadsId) return [];
  const items = [];
  let pageToken = '';
  while (items.length < limit) {
    const data = await ytFetch('playlistItems', {
      part: 'snippet',
      playlistId: uploadsId,
      maxResults: Math.min(50, limit - items.length),
      pageToken
    });
    items.push(...(data.items || []));
    if (!data.nextPageToken || !(data.items || []).length) break;
    pageToken = data.nextPageToken;
  }

  const ids = items
    .map(item => item?.snippet?.resourceId?.videoId)
    .filter(Boolean);

  if (!ids.length) return [];
  const chunks = [];
  for (let i = 0; i < ids.length; i += 50) chunks.push(ids.slice(i, i + 50).join(','));

  const detailBatches = await Promise.all(chunks.map(idChunk => ytFetch('videos', {
    part: 'snippet,status,liveStreamingDetails',
    id: idChunk
  })));

  return detailBatches
    .flatMap(batch => batch.items || [])
    .map(toVideoItem)
    .filter(Boolean)
    .filter(v => v.privacyStatus !== 'private')
    .sort((a, b) => new Date(b.publishedAt || 0) - new Date(a.publishedAt || 0));
}

async function getBroadcast(eventType) {
  const search = await ytFetch('search', {
    part: 'snippet',
    channelId: YT_CHANNEL_ID,
    eventType,
    type: 'video',
    videoEmbeddable: 'true',
    maxResults: 5
  });
  const ids = (search.items || []).map(i => i.id?.videoId).filter(Boolean);
  if (!ids.length) return null;

  const videos = await ytFetch('videos', { part: 'snippet,status,liveStreamingDetails', id: ids.join(',') });
  const items = (videos.items || [])
    .map(toVideoItem)
    .filter(Boolean)
    .filter(v => v.privacyStatus !== 'private' && v.embeddable);

  if (!items.length) return null;
  if (eventType === 'live') items.sort((a,b) => new Date(b.actualStartTime || b.publishedAt) - new Date(a.actualStartTime || a.publishedAt));
  else items.sort((a,b) => new Date(a.scheduledStartTime || a.publishedAt) - new Date(b.scheduledStartTime || b.publishedAt));
  return items[0];
}

function populateMonthFilter(videos) {
  const select = document.getElementById('videoMonthFilter');
  if (!select) return;

  const current = videoState.month;
  const options = [...new Map(videos
    .filter(v => v.monthKey && v.monthKey !== 'unknown')
    .map(v => [v.monthKey, v.monthLabel]))]
    .sort((a, b) => b[0].localeCompare(a[0]));

  select.innerHTML = '<option value="all">Todos los meses</option>' +
    options.map(([key, label]) => `<option value="${escapeHtml(key)}">${escapeHtml(label)}</option>`).join('');

  select.value = current;
}

function getFilteredVideos() {
  return videoState.all.filter(video => {
    const matchType = videoState.type === 'all' || video.category === videoState.type;
    const matchMonth = videoState.month === 'all' || video.monthKey === videoState.month;
    return matchType && matchMonth;
  });
}

function renderFeature(video, autoplay = false) {
  const media = document.getElementById('videoFeatureMedia');
  const type = document.getElementById('videoFeatureType');
  const date = document.getElementById('videoFeatureDate');
  const title = document.getElementById('videoFeatureTitle');
  const meta = document.getElementById('videoFeatureMeta');
  const desc = document.getElementById('videoFeatureDesc');
  const actions = document.getElementById('videoFeatureActions');
  if (!media || !type || !date || !title || !meta || !desc || !actions || !video) return;

  type.textContent = video.category;
  date.textContent = video.publishedAt ? fmtDate(video.publishedAt) : 'Sin fecha';
  title.textContent = video.title;
  meta.textContent = video.embeddable
    ? 'Disponible para reproducir dentro del sitio'
    : 'Este video debe abrirse directamente en YouTube';
  desc.textContent = video.description?.trim()
    ? video.description.trim().slice(0, 240) + (video.description.trim().length > 240 ? '…' : '')
    : 'Selecciona entre cultos, charlas, debates, avisos y otros contenidos del canal.';

  if (autoplay && video.embeddable) {
    media.innerHTML = `<iframe src="https://www.youtube-nocookie.com/embed/${video.videoId}?autoplay=1&controls=1&rel=0&playsinline=1" title="${escapeHtml(video.title)}" allowfullscreen allow="autoplay; encrypted-media; picture-in-picture"></iframe>`;
  } else {
    media.innerHTML = `
      ${video.thumb ? `<img src="${escapeHtml(video.thumb)}" alt="${escapeHtml(video.title)}">` : `<div class="video-feature-placeholder">Sin miniatura disponible</div>`}
      <div class="video-feature-overlay">
        <button type="button" class="video-feature-play" data-play-featured="${escapeHtml(video.videoId)}" aria-label="Reproducir ${escapeHtml(video.title)} aquí">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
        </button>
      </div>`;
  }

  const ytHref = videoUrl(video.videoId);
  if (video.embeddable) {
    actions.innerHTML = `
      <button type="button" class="video-btn video-btn-primary" data-play-featured="${escapeHtml(video.videoId)}">Ver aquí</button>
      <a class="video-btn video-btn-secondary" href="${escapeHtml(ytHref)}" target="_blank" rel="noopener">Ver en YouTube</a>`;
  } else {
    actions.innerHTML = `
      <a class="video-btn video-btn-primary" href="${escapeHtml(ytHref)}" target="_blank" rel="noopener">Ver en YouTube</a>
      <span class="video-note">YouTube no permite reproducir este video dentro del sitio.</span>`;
  }
}

function renderVideoStrip(videos) {
  const strip = document.getElementById('videoStrip');
  const count = document.getElementById('videoStripCount');
  if (!strip || !count) return;

  count.textContent = `${videos.length} video${videos.length === 1 ? '' : 's'} disponibles`;

  if (!videos.length) {
    strip.innerHTML = `<div class="video-empty">No hay videos para ese filtro todavía.</div>`;
    return;
  }

  strip.innerHTML = videos.map(video => `
    <button type="button" class="video-card ${video.videoId === videoState.selectedId ? 'active' : ''}" data-select-video="${escapeHtml(video.videoId)}" aria-label="Ver ${escapeHtml(video.title)}">
      <div class="video-card-thumb">
        ${video.thumb ? `<img src="${escapeHtml(video.thumb)}" alt="">` : ''}
        <span class="video-card-badge">${escapeHtml(video.category)}</span>
      </div>
      <div class="video-card-body">
        <p class="video-card-title">${escapeHtml(video.title)}</p>
        <p class="video-card-meta">${escapeHtml(fmtDate(video.publishedAt))}</p>
      </div>
    </button>
  `).join('');
}

function applyVideoFilters({ preserveSelection = true, autoplay = false } = {}) {
  videoState.filtered = getFilteredVideos();

  let featured = null;
  if (preserveSelection && videoState.selectedId) {
    featured = videoState.filtered.find(v => v.videoId === videoState.selectedId) || null;
  }
  if (!featured) {
    featured = videoState.filtered[0] || videoState.all[0] || null;
  }

  videoState.selectedId = featured?.videoId || null;
  if (featured) renderFeature(featured, autoplay);
  renderVideoStrip(videoState.filtered);
}

function setVideoTypeFilter(type) {
  videoState.type = type;
  document.querySelectorAll('.video-chip').forEach(btn => {
    btn.classList.toggle('active', btn.dataset.videoType === type);
  });
  applyVideoFilters({ preserveSelection: false });
}

function initVideoLibrary(videos) {
  videoState.all = videos;
  populateMonthFilter(videos);
  applyVideoFilters({ preserveSelection: false });
}

function renderEmbedBlocked(box, text, buttonLabel, videoId) {
  box.innerHTML = `
    <div class="stream-ph">
      <div class="stream-icon">
        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.35)" stroke-width="1.5"><polygon points="5 3 19 12 5 21 5 3"/></svg>
      </div>
      <p style="font-size:.84rem;line-height:1.6">${escapeHtml(text)}</p>
      <a href="${escapeHtml(videoUrl(videoId))}" target="_blank" rel="noopener" style="background:var(--gold);color:#0f0b32;border:none;padding:.6rem 1.3rem;border-radius:2px;font-size:.72rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;cursor:pointer;text-decoration:none">${escapeHtml(buttonLabel)}</a>
    </div>`;
}

function renderLive(video) {
  const box = qs('.stream-box'), pill = qs('.live-pill'), next = qs('.next-txt');
  if (!box || !video) return;

  if (!video.embeddable) {
    renderEmbedBlocked(box, 'La transmisión está activa, pero YouTube no permite reproducirla dentro del sitio.', 'Ver en YouTube', video.videoId);
    if (pill) pill.innerHTML = '<span class="live-dot-r"></span>EN VIVO AHORA';
    if (next) next.innerHTML = `📺 <strong>${escapeHtml(video.title)}</strong> · Abrir en YouTube`;
    return;
  }

  box.innerHTML = `<iframe src="https://www.youtube-nocookie.com/embed/${video.videoId}?autoplay=1&controls=1&rel=0&playsinline=1" allowfullscreen allow="autoplay;encrypted-media;picture-in-picture" style="width:100%;height:100%;border:none"></iframe>`;
  if (pill) pill.innerHTML = '<span class="live-dot-r"></span>EN VIVO AHORA';
  if (next) next.innerHTML = `📺 <strong>${escapeHtml(video.title)}</strong> · Transmisión en curso`;
}

function renderUpcoming(video) {
  const box = qs('.stream-box'), next = qs('.next-txt'), pill = qs('.live-pill');
  if (!box || !video) return;
  box.innerHTML = `<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;padding:1.25rem"><div style="max-width:520px;width:100%;text-align:center">${video.thumb ? `<img src="${escapeHtml(video.thumb)}" alt="" style="width:100%;aspect-ratio:16/9;object-fit:cover;border-radius:4px;border:1px solid rgba(255,255,255,.08);margin-bottom:1rem">` : ''}<p style="font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:var(--gold);margin-bottom:.65rem">Próxima transmisión programada</p><p style="font-size:.95rem;line-height:1.5;color:var(--white);margin-bottom:.85rem">${escapeHtml(video.title)}</p><p style="font-size:.82rem;color:var(--muted);margin-bottom:1rem">${video.scheduledStartTime ? escapeHtml(fmtDateTime(video.scheduledStartTime)) : 'Horario pendiente'}</p><a href="${escapeHtml(videoUrl(video.videoId))}" target="_blank" rel="noopener" style="display:inline-flex;background:var(--gold);color:#0f0b32;border:none;padding:.6rem 1.3rem;border-radius:2px;font-size:.72rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;cursor:pointer;text-decoration:none">Ver en YouTube</a></div></div>`;
  if (pill) pill.innerHTML = '<span class="live-dot-r"></span>PRÓXIMO EN VIVO';
  if (next) next.innerHTML = `Próxima transmisión: <strong>${video.scheduledStartTime ? escapeHtml(fmtDateTime(video.scheduledStartTime)) : 'Programada'}</strong>`;
}

function renderLastServiceFallback(video) {
  const box = qs('.stream-box'), next = qs('.next-txt'), pill = qs('.live-pill');
  if (!box || !video) return;
  box.innerHTML = `<div class="stream-ph"><div class="stream-icon"><svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.35)" stroke-width="1.5"><polygon points="5 3 19 12 5 21 5 3"/></svg></div><p style="font-size:.84rem;">No hay transmisión en vivo activa<br>ni programada en este momento</p><a href="${escapeHtml(videoUrl(video.videoId))}" target="_blank" rel="noopener" style="background:var(--gold);color:#0f0b32;border:none;padding:.6rem 1.3rem;border-radius:2px;font-size:.72rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;cursor:pointer;text-decoration:none">▶ Ver último video</a></div>`;
  if (pill) pill.innerHTML = '<span class="live-dot-r"></span>CANAL';
  if (next) next.innerHTML = `Destacado reciente: <strong>${escapeHtml(video.title)}</strong>`;
}

document.addEventListener('click', (event) => {
  const typeBtn = event.target.closest('[data-video-type]');
  if (typeBtn) {
    setVideoTypeFilter(typeBtn.dataset.videoType || 'all');
    return;
  }

  const selectBtn = event.target.closest('[data-select-video]');
  if (selectBtn) {
    const video = videoState.all.find(v => v.videoId === selectBtn.dataset.selectVideo);
    if (video) {
      videoState.selectedId = video.videoId;
      renderFeature(video, false);
      renderVideoStrip(videoState.filtered);
    }
    return;
  }

  const playBtn = event.target.closest('[data-play-featured]');
  if (playBtn) {
    const video = videoState.all.find(v => v.videoId === playBtn.dataset.playFeatured);
    if (video) {
      videoState.selectedId = video.videoId;
      renderFeature(video, true);
      renderVideoStrip(videoState.filtered);
    }
  }
});

document.getElementById('videoMonthFilter')?.addEventListener('change', (event) => {
  videoState.month = event.target.value || 'all';
  applyVideoFilters({ preserveSelection: false });
});

async function initYouTubeSections() {
  if (!ytOK()) return;
  try {
    const recentVideos = await getRecentUploads(24);
    const latest = recentVideos[0] || null;
    if (recentVideos.length) initVideoLibrary(recentVideos);

    const live = await getBroadcast('live');
    if (live) { renderLive(live); return; }

    const upcoming = await getBroadcast('upcoming');
    if (upcoming) { renderUpcoming(upcoming); return; }

    if (latest) renderLastServiceFallback(latest);
  } catch(e) {
    console.warn('YouTube:', e);
    const featureTitle = document.getElementById('videoFeatureTitle');
    const featureMeta = document.getElementById('videoFeatureMeta');
    const featureDesc = document.getElementById('videoFeatureDesc');
    const media = document.getElementById('videoFeatureMedia');
    const next = qs('.next-txt');
    const strip = document.getElementById('videoStrip');
    const count = document.getElementById('videoStripCount');

    if (featureTitle) featureTitle.textContent = 'No se pudieron cargar los videos';
    if (featureMeta) featureMeta.textContent = 'Verificá la API key y el channel ID';
    if (featureDesc) featureDesc.textContent = 'La biblioteca del canal no pudo conectarse con YouTube.';
    if (media) media.innerHTML = '<div class="video-feature-placeholder">No se pudo cargar el reproductor del canal.</div>';
    if (strip) strip.innerHTML = '<div class="video-empty">No se pudo consultar la lista de videos.</div>';
    if (count) count.textContent = 'Sin datos';
    if (next) next.innerHTML = 'No se pudo consultar el canal';
  }
}

initYouTubeSections();
</script>
</body>
</html>