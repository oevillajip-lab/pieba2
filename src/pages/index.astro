<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PIEBA | Iglesia</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Raleway:ital,wght@0,300;0,400;0,500;0,600;1,300&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --navy:        #0f0b32;
      --navy-deep:   #07051e;
      --navy-light:  #1c1760;
      --white:       #ffffff;
      --gold:        #c9a96e;
      --gold-dim:    rgba(201,169,110,0.25);
      --muted:       rgba(255,255,255,0.55);
      --glass:       rgba(255,255,255,0.05);
      --glass-b:     rgba(255,255,255,0.1);
    }

    html, body {
  height: 100%;
  margin: 0;
}

    body {
      font-family: 'Raleway', sans-serif;
      background: var(--navy-deep);
      color: var(--white);
    }

.scroll-wrap {
  height: 100dvh;
  min-height: 100dvh;
  overflow-y: auto;
  scroll-snap-type: y mandatory;
  scroll-behavior: smooth;
  -webkit-overflow-scrolling: touch;
}

.page {
  min-height: 100dvh;
  height: auto;
  scroll-snap-align: start;
  position: relative;
  overflow: visible;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 6.5rem 0 2.5rem;
}

    .topnav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      padding: 1.2rem 3rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: linear-gradient(to bottom, rgba(7,5,30,.95) 0%, transparent 100%);
      transition: background .4s, backdrop-filter .4s;
    }
    .topnav.scrolled {
      background: rgba(7,5,30,.93);
      backdrop-filter: blur(14px);
    }
    .nav-logo { display: flex; align-items: center; gap: .7rem; text-decoration: none; }
    .nav-logo svg { height: 38px; width: 38px; }
    .nav-logo-text { font-family: 'Cinzel', serif; font-weight: 700; font-size: 1.05rem; color: var(--white); letter-spacing: .1em; }
    .nav-links { display: flex; list-style: none; gap: 2.25rem; }
    .nav-links a { font-size: .75rem; font-weight: 500; text-transform: uppercase; letter-spacing: .18em; color: var(--muted); text-decoration: none; transition: color .3s; }
    .nav-links a:hover, .nav-links a.active { color: var(--gold); }
    .nav-cta { font-size: .74rem; font-weight: 600; text-transform: uppercase; letter-spacing: .14em; color: var(--navy); background: var(--gold); padding: .5rem 1.35rem; border-radius: 2px; text-decoration: none; transition: opacity .3s; }
    .nav-cta:hover { opacity: .82; }
    .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 4px; z-index: 110; }
    .hamburger span { display: block; width: 26px; height: 2px; background: var(--white); transition: .3s; }
    .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; }
    .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    .side-dots { position: fixed; right: 1.6rem; top: 50%; transform: translateY(-50%); z-index: 99; display: flex; flex-direction: column; gap: .7rem; }
    .dot { width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,.22); cursor: pointer; transition: background .3s, transform .3s; }
    .dot.active { background: var(--gold); transform: scale(1.35); }

    .mobile-nav { position: fixed; inset: 0; z-index: 95; background: rgba(7,5,30,.97); backdrop-filter: blur(14px); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2.25rem; transform: translateX(100%); transition: transform .45s cubic-bezier(.77,0,.175,1); }
    .mobile-nav.open { transform: translateX(0); }
    .mobile-nav a { font-family: 'Cinzel', serif; font-size: 1.5rem; color: var(--white); text-decoration: none; letter-spacing: .15em; transition: color .3s; }
    .mobile-nav a:hover { color: var(--gold); }

    .reveal { opacity: 0; transform: translateY(28px); transition: opacity .75s ease, transform .75s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .d1 { transition-delay: .1s; }
    .d2 { transition-delay: .2s; }
    .d3 { transition-delay: .3s; }
    .d4 { transition-delay: .45s; }

    .gold-line { width: 46px; height: 2px; background: var(--gold); margin: 1.1rem auto; }
    .gold-line.left { margin: 1.1rem 0; }
    .section-label { font-size: .68rem; font-weight: 600; letter-spacing: .3em; text-transform: uppercase; color: var(--gold); }
    .section-title { font-family: 'Cinzel', serif; font-size: clamp(1.9rem, 3.5vw, 2.9rem); font-weight: 600; line-height: 1.15; margin-top: .85rem; }
    .page-num { position: absolute; bottom: 1.75rem; right: 2.5rem; font-family: 'Cinzel', serif; font-size: .62rem; letter-spacing: .3em; color: rgba(255,255,255,.18); }

    #inicio { background: var(--navy-deep); }
    #inicio canvas { position: absolute; inset: 0; width: 100%; height: 100%; }
    .hero-glow { position: absolute; inset: 0; background: radial-gradient(ellipse 65% 55% at 50% 60%, rgba(15,11,50,.0) 0%, rgba(7,5,30,.9) 100%); pointer-events: none; }
    .hero-content { position: relative; z-index: 2; text-align: center; display: flex; flex-direction: column; align-items: center; }
    .hero-logo { width: 400px; height: 400px; margin-bottom: 2rem; font-size: clamp(1.6rem, 4vw, 3rem); animation: fadeDown 1.2s ease both; filter: drop-shadow(0 0 24px rgba(201,169,110,.35)); }
    .hero-name { font-family: 'Cinzel', serif;  font-weight: 700; letter-spacing: .18em; line-height: 1; animation: fadeUp 1.2s ease .2s both; }
    .hero-sub { font-size: clamp(.8rem, 1.3vw, 1rem); font-weight: 300; letter-spacing: .35em; text-transform: uppercase; color: var(--gold); margin-top: .7rem; animation: fadeUp 1.2s ease .35s both; }
    .hero-verse { font-style: italic; font-size: clamp(.8rem, 1.1vw, .95rem); color: var(--muted); max-width: 440px; margin-top: 2rem; line-height: 1.8; animation: fadeUp 1.2s ease .5s both; }
    .hero-verse cite { color: var(--gold); font-style: normal; font-size: .8em; letter-spacing: .08em; }
    .scroll-cue { position: absolute; bottom: 2.25rem; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: .4rem; opacity: .35; animation: cueBounce 2.5s ease infinite; }
    .scroll-cue span { font-size: .6rem; letter-spacing: .25em; text-transform: uppercase; }
    .scroll-cue::after { content: ''; width: 1px; height: 36px; background: var(--white); }

    #nosotros { background: var(--navy); }
    .nos-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; padding: 2rem 6rem; max-width: 1200px; width: 100%; }
    .nos-body { font-size: .92rem; line-height: 1.9; color: var(--muted); margin-top: 1.4rem; }
    .nos-list { list-style: none; margin-top: 1.75rem; display: flex; flex-direction: column; gap: .9rem; }
    .nos-list li { display: flex; align-items: flex-start; gap: 1rem; }
    .nos-list li::before { content: ''; flex-shrink: 0; width: 22px; height: 1px; background: var(--gold); margin-top: .68em; }
    .nos-list li span { font-size: .88rem; color: var(--muted); line-height: 1.6; }
    .nos-visual { display: flex; align-items: center; justify-content: center; position: relative; }
    .ring { width: 300px; height: 300px; border-radius: 50%; border: 1px solid var(--gold-dim); display: flex; align-items: center; justify-content: center; position: relative; animation: spin 30s linear infinite; }
    .ring::before { content: ''; position: absolute; width: 248px; height: 248px; border-radius: 50%; border: 1px solid var(--glass-b); }
    .ring-inner { width: 188px; height: 188px; background: var(--glass); border: 1px solid var(--glass-b); border-radius: 50%; display: flex; align-items: center; justify-content: center; animation: spin 30s linear infinite reverse; }
    .ring-inner svg { width: 110px; height: 110px; opacity: .85; }
    .stat { position: absolute; padding: .7rem 1.15rem; text-align: center; background: rgba(201,169,110,.1); border: 1px solid var(--gold-dim); border-radius: 6px; backdrop-filter: blur(8px); animation: spin 30s linear infinite; }
    .stat:nth-child(2) { top: 6%; right: -24px; }
    .stat:nth-child(3) { bottom: 10%; left: -24px; }
    .stat-num { font-family: 'Cinzel', serif; font-size: 1.4rem; font-weight: 700; color: var(--gold); animation: spin 30s linear infinite reverse; }
    .stat-lbl { font-size: .62rem; letter-spacing: .14em; text-transform: uppercase; color: var(--muted); margin-top: .18rem; animation: spin 30s linear infinite reverse; }

    #cultos { background: linear-gradient(140deg, var(--navy-deep) 0%, var(--navy) 100%); }
    .cultos-wrap { text-align: center; max-width: 1080px; width: 100%; padding: 2rem 3rem; }
    .culto-cards { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.25rem; margin-top: 2.5rem; }
    .culto-card { background: var(--glass); border: 1px solid var(--glass-b); border-radius: 3px; padding: 1.75rem 1.4rem; position: relative; overflow: hidden; transition: border-color .3s, transform .3s; }
    .culto-card::after { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, transparent, var(--gold), transparent); transform: scaleX(0); transition: transform .4s; }
    .culto-card:hover { border-color: var(--gold-dim); transform: translateY(-5px); }
    .culto-card:hover::after { transform: scaleX(1); }
    .culto-dia { font-size: .68rem; letter-spacing: .28em; text-transform: uppercase; color: var(--gold); }
    .culto-nombre { font-family: 'Cinzel', serif; font-size: 1.15rem; font-weight: 600; margin-top: .65rem; }
    .culto-hora { font-size: 2.1rem; font-weight: 300; margin-top: .85rem; }
    .culto-desc { font-size: .78rem; color: var(--muted); margin-top: .65rem; line-height: 1.65; }
    .sermon-row { margin-top: 2rem; background: var(--glass); border: 1px solid var(--glass-b); border-radius: 3px; padding: 1.25rem 1.75rem; display: flex; align-items: center; gap: 1.75rem; text-align: left; }
    .sermon-badge { font-size: .62rem; letter-spacing: .18em; text-transform: uppercase; color: var(--navy); background: var(--gold); padding: .28rem .7rem; border-radius: 2px; white-space: nowrap; flex-shrink: 0; }
    .sermon-title { font-family: 'Cinzel', serif; font-size: .95rem; font-weight: 600; }
    .sermon-meta { font-size: .74rem; color: var(--muted); margin-top: .25rem; }
    .play-btn { margin-left: auto; flex-shrink: 0; width: 42px; height: 42px; border-radius: 50%; background: var(--gold-dim); border: 1px solid var(--gold); display: flex; align-items: center; justify-content: center; cursor: pointer; transition: background .3s; }
    .play-btn:hover { background: rgba(201,169,110,.45); }
    .play-btn svg { fill: var(--gold); margin-left: 2px; }

    #sermonPlayerWrap {
      display: none;
      margin-top: 1rem;
      width: 100%;
    }

    #envivo { background: var(--navy-deep); }
    .envivo-wrap { text-align: center; max-width: 880px; width: 100%; padding: 2rem 3rem; }
    .live-pill { display: inline-flex; align-items: center; gap: .5rem; background: rgba(220,50,50,.12); border: 1px solid rgba(220,50,50,.35); border-radius: 100px; padding: .35rem .9rem; font-size: .68rem; letter-spacing: .2em; text-transform: uppercase; color: #ff7070; margin-bottom: 1.4rem; }
    .live-dot-r { width: 7px; height: 7px; border-radius: 50%; background: #ff4444; animation: pulse 1.4s ease infinite; }
    .stream-box { margin-top: 1.75rem; border-radius: 5px; overflow: hidden; border: 1px solid var(--glass-b); background: rgba(0,0,0,.38); aspect-ratio: 16/9; max-height: 48vh; display: flex; align-items: center; justify-content: center; }
    .stream-ph { display: flex; flex-direction: column; align-items: center; gap: .9rem; color: var(--muted); }
    .stream-icon { width: 68px; height: 68px; border-radius: 50%; background: rgba(255,255,255,.05); border: 1px solid var(--glass-b); display: flex; align-items: center; justify-content: center; }
    .stream-hint { font-size: .68rem; color: var(--gold); letter-spacing: .14em; text-transform: uppercase; }
    .stream-box iframe { width: 100%; height: 100%; border: none; }
    .next-txt { margin-top: 1.4rem; font-size: .8rem; color: var(--muted); }
    .next-txt strong { color: var(--gold); }

    #contacto { background: var(--navy); }
    .cont-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; padding: 2rem 6rem; max-width: 1100px; width: 100%; }
    .cont-items { display: flex; flex-direction: column; gap: 1.5rem; }
    .cont-item { display: flex; align-items: flex-start; gap: 1.1rem; }
    .cont-ico { width: 40px; height: 40px; flex-shrink: 0; border-radius: 3px; background: var(--gold-dim); border: 1px solid rgba(201,169,110,.4); display: flex; align-items: center; justify-content: center; }
    .cont-ico svg { fill: var(--gold); }
    .cont-lbl { font-size: .62rem; letter-spacing: .2em; text-transform: uppercase; color: var(--gold); }
    .cont-val { font-size: .88rem; color: var(--muted); margin-top: .22rem; line-height: 1.55; }
    .social-row { display: flex; gap: .6rem; margin-top: .35rem; }
    .soc-btn { width: 36px; height: 36px; border-radius: 50%; background: var(--glass); border: 1px solid var(--glass-b); display: flex; align-items: center; justify-content: center; cursor: pointer; text-decoration: none; transition: background .3s, border-color .3s; }
    .soc-btn:hover { background: var(--gold-dim); border-color: var(--gold); }
    .soc-btn svg { fill: var(--white); }
    .cont-map { border-radius: 5px; overflow: hidden; border: 1px solid var(--glass-b); background: rgba(0,0,0,.28); min-height: 260px; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: .65rem; color: var(--muted); font-size: .78rem; }
    .cont-map iframe { width: 100%; height: 100%; border: none; }

    #ofrendar { background: linear-gradient(140deg, var(--navy-deep) 0%, var(--navy-light) 100%); }
    .ofr-wrap { text-align: center; max-width: 680px; width: 100%; padding: 2rem 3rem; }
    .ofr-verse { font-style: italic; font-size: .84rem; color: var(--muted); max-width: 420px; margin: 0 auto; line-height: 1.85; }
    .ofr-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-top: 2.25rem; }
    .ofr-card { background: var(--glass); border: 1px solid var(--glass-b); border-radius: 3px; padding: 1.75rem 1.4rem; transition: border-color .3s; }
    .ofr-card:hover { border-color: var(--gold-dim); }
    .ofr-card-title { font-family: 'Cinzel', serif; font-size: .95rem; color: var(--gold); margin-bottom: .9rem; }
    .ofr-detail { font-size: .8rem; color: var(--muted); line-height: 2; }
    .ofr-detail strong { color: var(--white); }
    .qr-ph { width: 96px; height: 96px; margin: 0 auto 1rem; background: rgba(255,255,255,.07); border: 1px dashed rgba(201,169,110,.3); border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: .65rem; color: var(--muted); text-transform: uppercase; letter-spacing: .1em; }
    .ofr-footnote { font-size: .72rem; color: var(--muted); margin-top: 1.75rem; }

    @keyframes fadeDown  { from{opacity:0;transform:translateY(-22px)} to{opacity:1;transform:translateY(0)} }
    @keyframes fadeUp    { from{opacity:0;transform:translateY(22px)}  to{opacity:1;transform:translateY(0)} }
    @keyframes cueBounce { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(9px)} }
    @keyframes pulse     { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.45;transform:scale(.68)} }
    @keyframes spin      { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }

@media (max-width: 900px) {
  html, body {
    overflow: auto;
  }

  .scroll-wrap {
    height: auto;
    min-height: 100dvh;
    overflow-y: auto;
    scroll-snap-type: none;
  }

  .page {
    min-height: auto;
    height: auto;
    overflow: visible;
    justify-content: flex-start;
    padding: 5.8rem 0 2.2rem;
  }

  .page-num {
    display: none;
  }

  .topnav {
    padding: 1rem 1.1rem;
  }

  .nav-links,
  .nav-cta {
    display: none;
  }

  .hamburger {
    display: flex;
  }

  .side-dots {
    display: none;
  }

  #inicio {
    min-height: 100dvh;
    justify-content: center;
    padding-top: 5.5rem;
    padding-bottom: 2rem;
  }

  .hero-content {
    width: 100%;
    padding: 0 1.2rem;
  }

  .hero-logo {
    width: min(58vw, 220px);
    height: min(58vw, 220px);
    margin-bottom: 1.1rem;
  }

  .hero-name {
    font-size: clamp(1.35rem, 7vw, 2.1rem);
    line-height: 1.15;
    letter-spacing: .08em;
  }

  .hero-sub {
    font-size: .72rem;
    letter-spacing: .16em;
    line-height: 1.7;
    margin-top: .8rem;
    text-align: center;
  }

  .hero-verse {
    font-size: .82rem;
    line-height: 1.7;
    max-width: 92%;
    margin-top: 1.35rem;
  }

  .scroll-cue {
    bottom: 1rem;
  }

  .nos-grid {
    grid-template-columns: 1fr;
    padding: 0 1.2rem;
    gap: 1.7rem;
    max-width: 100%;
  }

  .nos-visual {
    display: none;
  }

  .section-title {
    font-size: clamp(1.6rem, 7vw, 2.3rem);
    line-height: 1.15;
  }

  .nos-body {
    font-size: .9rem;
    line-height: 1.8;
  }

  .nos-list li span {
    font-size: .86rem;
  }

  .cultos-wrap {
    width: 100%;
    max-width: 100%;
    padding: 0 1.2rem;
  }

  .culto-cards {
    grid-template-columns: 1fr;
    gap: .9rem;
    margin-top: 1.6rem;
  }

  .culto-card {
    padding: 1.3rem 1rem;
  }

  .culto-hora {
    font-size: 1.7rem;
  }

  .sermon-row {
    margin-top: 1.2rem;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: .9rem;
    padding: 1rem;
  }

  .sermon-badge {
    order: 1;
  }

  .sermon-row > div:not(.play-btn) {
    order: 2;
    width: calc(100% - 56px);
    min-width: 0;
  }

  .sermon-title {
    font-size: .9rem;
    line-height: 1.45;
    word-break: break-word;
  }

  .sermon-meta {
    font-size: .74rem;
    line-height: 1.5;
  }

  .play-btn {
    order: 3;
    margin-left: auto;
    width: 40px;
    height: 40px;
  }

  #sermonPlayerWrap {
    margin-top: .9rem;
  }

  .envivo-wrap {
    width: 100%;
    max-width: 100%;
    padding: 0 1.2rem;
  }

  .stream-box {
    margin-top: 1.3rem;
    max-height: none;
    min-height: 220px;
  }

  .next-txt {
    font-size: .8rem;
    line-height: 1.6;
  }

  .cont-grid {
    grid-template-columns: 1fr;
    padding: 0 1.2rem;
    gap: 1.6rem;
    max-width: 100%;
  }

  .cont-items {
    gap: 1.2rem;
  }

  .cont-item {
    gap: .9rem;
  }

  .cont-val {
    font-size: .86rem;
  }

  .cont-map {
    min-height: 220px;
  }

  .ofr-wrap {
    width: 100%;
    max-width: 100%;
    padding: 0 1.2rem;
  }

  .ofr-cards {
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .ofr-card {
    padding: 1.3rem 1rem;
  }

  .ofr-verse {
    font-size: .82rem;
    line-height: 1.75;
  }
}

@media (max-width: 480px) {
  .hero-name {
    font-size: clamp(1.2rem, 8vw, 1.7rem);
  }

  .hero-sub {
    font-size: .66rem;
    letter-spacing: .12em;
  }

  .section-title {
    font-size: clamp(1.4rem, 8vw, 2rem);
  }

  .culto-card,
  .ofr-card {
    padding: 1.1rem .9rem;
  }

  .sermon-row {
    padding: .9rem;
  }

  .topnav {
    padding: .9rem 1rem;
  }
}
    
  </style>
</head>
<body>

<nav class="topnav" id="topnav">
