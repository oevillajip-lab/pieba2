<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PIEBA | Iglesia</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Raleway:ital,wght@0,300;0,400;0,500;0,600;1,300&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --navy:        #0f0b32;
      --navy-deep:   #07051e;
      --navy-light:  #1c1760;
      --white:       #ffffff;
      --gold:        #c9a96e;
      --gold-dim:    rgba(201,169,110,0.25);
      --muted:       rgba(255,255,255,0.55);
      --glass:       rgba(255,255,255,0.05);
      --glass-b:     rgba(255,255,255,0.1);
    }

    html, body { height: 100%; margin: 0; overflow: hidden; }

    body {
      font-family: 'Raleway', sans-serif;
      background: var(--navy-deep);
      color: var(--white);
    }

    .scroll-wrap {
      height: 100dvh;
      min-height: 100dvh;
      overflow-y: auto;
      scroll-snap-type: y mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
    }

.page {
  min-height: 100dvh;
  height: auto;
  scroll-snap-align: start;
  scroll-snap-stop: always;
  position: relative;
  overflow: visible;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 6.5rem 0 2.5rem;
}

    /* ── NAV ── */
    .topnav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      padding: 1.1rem 2.5rem;
      display: flex; align-items: center; justify-content: space-between;
      background: linear-gradient(to bottom, rgba(7,5,30,.95) 0%, transparent 100%);
      transition: background .4s, backdrop-filter .4s;
    }
    .topnav.scrolled { background: rgba(7,5,30,.93); backdrop-filter: blur(14px); }
    .nav-logo { display: flex; align-items: center; gap: .7rem; text-decoration: none; }
    .nav-logo svg { height: 34px; width: 34px; }
    .nav-logo-text { font-family: 'Cinzel', serif; font-weight: 700; font-size: 1rem; color: var(--white); letter-spacing: .1em; }
    .nav-links { display: flex; list-style: none; gap: 1.6rem; }
    .nav-links a { font-size: .68rem; font-weight: 500; text-transform: uppercase; letter-spacing: .16em; color: var(--muted); text-decoration: none; transition: color .3s; }
    .nav-links a:hover, .nav-links a.active { color: var(--gold); }
    .nav-cta { font-size: .68rem; font-weight: 600; text-transform: uppercase; letter-spacing: .12em; color: var(--navy); background: var(--gold); padding: .45rem 1.1rem; border-radius: 2px; text-decoration: none; transition: opacity .3s; white-space: nowrap; }
    .nav-cta:hover { opacity: .82; }
.hamburger {
  display: none;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 5px;
  cursor: pointer;
  padding: 4px;
  z-index: 160;
  position: relative;
  background: transparent;
  border: 0;
  outline: none;
  appearance: none;
  -webkit-appearance: none;
}
    .hamburger span { display: block; width: 26px; height: 2px; background: var(--white); transition: .3s; }
    .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; }
    .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    /* ── SIDE DOTS ── */
    .side-dots { position: fixed; right: 1.4rem; top: 50%; transform: translateY(-50%); z-index: 99; display: flex; flex-direction: column; gap: .55rem; }
    .dot { width: 7px; height: 7px; border-radius: 50%; background: rgba(255,255,255,.22); cursor: pointer; transition: background .3s, transform .3s; border: 0; padding: 0; appearance: none; -webkit-appearance: none; }
    .dot.active { background: var(--gold); transform: scale(1.35); }

    /* ── MOBILE NAV ── */
.mobile-nav {
  display: none;
  position: fixed;
  top: 64px;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 140;
  background: rgba(7,5,30,.98);
  backdrop-filter: blur(14px);
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  gap: 1.1rem;
  padding: 1.5rem 1.25rem 2.5rem;
  overflow-y: auto;
}

.mobile-nav.open {
  display: flex;
}

.mobile-nav a {
  font-family: 'Cinzel', serif;
  font-size: 1.1rem;
  color: var(--white);
  text-decoration: none;
  letter-spacing: .12em;
  transition: color .3s;
}

.mobile-nav a:hover,
.mobile-nav a.active {
  color: var(--gold);
}

    /* ── REVEAL ── */
    .reveal { opacity: 0; transform: translateY(28px); transition: opacity .75s ease, transform .75s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .d1 { transition-delay: .1s; } .d2 { transition-delay: .2s; } .d3 { transition-delay: .3s; } .d4 { transition-delay: .45s; }

    /* ── SHARED ── */
    .gold-line { width: 46px; height: 2px; background: var(--gold); margin: 1.1rem auto; }
    .gold-line.left { margin: 1.1rem 0; }
    .section-label { font-size: .68rem; font-weight: 600; letter-spacing: .3em; text-transform: uppercase; color: var(--gold); }
    .section-title { font-family: 'Cinzel', serif; font-size: clamp(1.9rem, 3.5vw, 2.9rem); font-weight: 600; line-height: 1.15; margin-top: .85rem; }
    .page-num { position: absolute; bottom: 1.75rem; right: 2.5rem; font-family: 'Cinzel', serif; font-size: .62rem; letter-spacing: .3em; color: rgba(255,255,255,.18); }

    /* ── INICIO ── */
    #inicio { background: var(--navy-deep); }
    #inicio canvas { position: absolute; inset: 0; width: 100%; height: 100%; }
    .hero-glow { position: absolute; inset: 0; background: radial-gradient(ellipse 65% 55% at 50% 60%, rgba(15,11,50,.0) 0%, rgba(7,5,30,.9) 100%); pointer-events: none; }
    .hero-content { position: relative; z-index: 2; text-align: center; display: flex; flex-direction: column; align-items: center; }
    .hero-logo { width: 340px; height: 340px; margin-bottom: 1.5rem; animation: fadeDown 1.2s ease both; filter: drop-shadow(0 0 24px rgba(201,169,110,.35)); }
    .hero-name { font-family: 'Cinzel', serif; font-weight: 700; letter-spacing: .18em; line-height: 1; animation: fadeUp 1.2s ease .2s both; font-size: clamp(1.2rem, 2.5vw, 2rem); max-width: 600px; }
    .hero-sub { font-size: clamp(.75rem, 1.2vw, .95rem); font-weight: 300; letter-spacing: .35em; text-transform: uppercase; color: var(--gold); margin-top: .7rem; animation: fadeUp 1.2s ease .35s both; }
    .hero-verse { font-style: italic; font-size: clamp(.78rem, 1vw, .92rem); color: var(--muted); max-width: 420px; margin-top: 1.75rem; line-height: 1.8; animation: fadeUp 1.2s ease .5s both; }
    .hero-verse cite { color: var(--gold); font-style: normal; font-size: .8em; letter-spacing: .08em; }
    .scroll-cue { position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: .4rem; opacity: .35; animation: cueBounce 2.5s ease infinite; }
    .scroll-cue span { font-size: .6rem; letter-spacing: .25em; text-transform: uppercase; }
    .scroll-cue::after { content: ''; width: 1px; height: 36px; background: var(--white); }

    /* ── NOSOTROS ── */
    #nosotros { background: var(--navy); }
    .nos-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; padding: 2rem 6rem; max-width: 1200px; width: 100%; }
    .nos-body { font-size: .92rem; line-height: 1.9; color: var(--muted); margin-top: 1.4rem; }
    .nos-list { list-style: none; margin-top: 1.75rem; display: flex; flex-direction: column; gap: .9rem; }
    .nos-list li { display: flex; align-items: flex-start; gap: 1rem; }
    .nos-list li::before { content: ''; flex-shrink: 0; width: 22px; height: 1px; background: var(--gold); margin-top: .68em; }
    .nos-list li span { font-size: .88rem; color: var(--muted); line-height: 1.6; }
    .nos-visual { display: flex; align-items: center; justify-content: center; position: relative; }
    .ring { width: 300px; height: 300px; border-radius: 50%; border: 1px solid var(--gold-dim); display: flex; align-items: center; justify-content: center; position: relative; animation: spin 30s linear infinite; }
    .ring::before { content: ''; position: absolute; width: 248px; height: 248px; border-radius: 50%; border: 1px solid var(--glass-b); }
    .ring-inner { width: 188px; height: 188px; background: var(--glass); border: 1px solid var(--glass-b); border-radius: 50%; display: flex; align-items: center; justify-content: center; animation: spin 30s linear infinite reverse; }
    .ring-inner svg { width: 110px; height: 110px; opacity: .85; }
    .stat { position: absolute; padding: .7rem 1.15rem; text-align: center; background: rgba(201,169,110,.1); border: 1px solid var(--gold-dim); border-radius: 6px; backdrop-filter: blur(8px); animation: spin 30s linear infinite; }
    .stat:nth-child(2) { top: 6%; right: -24px; }
    .stat:nth-child(3) { bottom: 10%; left: -24px; }
    .stat-num { font-family: 'Cinzel', serif; font-size: 1.4rem; font-weight: 700; color: var(--gold); animation: spin 30s linear infinite reverse; }
    .stat-lbl { font-size: .62rem; letter-spacing: .14em; text-transform: uppercase; color: var(--muted); margin-top: .18rem; animation: spin 30s linear infinite reverse; }

    /* ── CULTOS ── */
    #cultos { background: linear-gradient(140deg, var(--navy-deep) 0%, var(--navy) 100%); }
    .cultos-wrap { text-align: center; max-width: 1180px; width: 100%; padding: 2rem 3rem; }
    .culto-cards { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.25rem; margin-top: 2.5rem; }
    .culto-card { background: var(--glass); border: 1px solid var(--glass-b); border-radius: 3px; padding: 1.75rem 1.4rem; position: relative; overflow: hidden; transition: border-color .3s, transform .3s; }
    .culto-card::after { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, transparent, var(--gold), transparent); transform: scaleX(0); transition: transform .4s; }
    .culto-card:hover { border-color: var(--gold-dim); transform: translateY(-5px); }
    .culto-card:hover::after { transform: scaleX(1); }
    .culto-dia { font-size: .68rem; letter-spacing: .28em; text-transform: uppercase; color: var(--gold); }
    .culto-nombre { font-family: 'Cinzel', serif; font-size: 1.15rem; font-weight: 600; margin-top: .65rem; }
    .culto-hora { font-size: 2.1rem; font-weight: 300; margin-top: .85rem; }
    .culto-desc { font-size: .78rem; color: var(--muted); margin-top: .65rem; line-height: 1.65; }

    .video-library { margin-top: 2rem; text-align: left; background: rgba(255,255,255,.03); border: 1px solid var(--glass-b); border-radius: 8px; padding: 1.5rem; }
    .video-library-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 1.2rem; flex-wrap: wrap; }
    .video-library-kicker { font-size: .66rem; letter-spacing: .18em; text-transform: uppercase; color: var(--gold); }
    .video-library-title { margin-top: .45rem; font-family: 'Cinzel', serif; font-size: 1.15rem; font-weight: 600; color: var(--white); }
    .video-controls { display: flex; align-items: center; gap: .9rem; flex-wrap: wrap; justify-content: flex-end; }
    .video-filter-chips { display: flex; gap: .55rem; flex-wrap: wrap; }
    .video-chip { background: rgba(255,255,255,.04); color: var(--muted); border: 1px solid var(--glass-b); border-radius: 999px; padding: .52rem .85rem; font-size: .68rem; letter-spacing: .08em; text-transform: uppercase; cursor: pointer; transition: .25s ease; }
    .video-chip:hover, .video-chip.active { color: var(--navy); background: var(--gold); border-color: var(--gold); }
    .video-month-wrap { display: flex; align-items: center; gap: .5rem; }
    .video-month-wrap label { font-size: .68rem; letter-spacing: .14em; text-transform: uppercase; color: var(--gold); }
    .video-month-select { min-width: 185px; background: rgba(255,255,255,.04); color: var(--white); border: 1px solid var(--glass-b); border-radius: 6px; padding: .72rem .85rem; }
    .video-feature { display: grid; grid-template-columns: 1.4fr 1fr; gap: 1.2rem; margin-top: 1.3rem; }
    .video-feature-media { position: relative; min-height: 320px; border-radius: 8px; overflow: hidden; border: 1px solid var(--glass-b); background: rgba(0,0,0,.45); }
    .video-feature-media iframe, .video-feature-media img { width: 100%; height: 100%; border: 0; object-fit: cover; display: block; }
    .video-feature-placeholder { min-height: 320px; display: flex; align-items: center; justify-content: center; text-align: center; color: var(--muted); padding: 2rem; }
    .video-feature-overlay { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: linear-gradient(to top, rgba(7,5,30,.88), rgba(7,5,30,.2)); }
    .video-feature-play { width: 82px; height: 82px; border-radius: 50%; border: 1px solid rgba(201,169,110,.65); background: rgba(201,169,110,.15); display: flex; align-items: center; justify-content: center; color: var(--gold); cursor: pointer; backdrop-filter: blur(8px); }
    .video-feature-play svg { margin-left: 4px; }
    .video-feature-body { background: rgba(255,255,255,.03); border: 1px solid var(--glass-b); border-radius: 8px; padding: 1.15rem; display: flex; flex-direction: column; }
    .video-feature-topline { display: flex; gap: .65rem; align-items: center; flex-wrap: wrap; }
    .video-tag { display: inline-flex; align-items: center; gap: .35rem; padding: .32rem .62rem; border-radius: 999px; background: rgba(201,169,110,.14); border: 1px solid rgba(201,169,110,.25); color: var(--gold); font-size: .64rem; letter-spacing: .14em; text-transform: uppercase; }
    .video-date { font-size: .72rem; color: var(--muted); }
    .video-feature-title { margin-top: .8rem; font-family: 'Cinzel', serif; font-size: 1.3rem; line-height: 1.35; color: var(--white); }
    .video-feature-meta { margin-top: .5rem; font-size: .78rem; color: var(--gold); letter-spacing: .06em; }
    .video-feature-desc { margin-top: .9rem; color: var(--muted); font-size: .84rem; line-height: 1.7; }
    .video-feature-actions { margin-top: auto; display: flex; gap: .7rem; flex-wrap: wrap; padding-top: 1.2rem; }
    .video-btn { display: inline-flex; align-items: center; justify-content: center; min-height: 42px; padding: .72rem 1rem; border-radius: 4px; text-decoration: none; font-size: .72rem; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; border: 1px solid transparent; cursor: pointer; }
    .video-btn-primary { background: var(--gold); color: var(--navy); border-color: var(--gold); }
    .video-btn-secondary { background: transparent; color: var(--white); border-color: var(--glass-b); }
    .video-btn-disabled { background: rgba(255,255,255,.04); color: var(--muted); border-color: var(--glass-b); cursor: not-allowed; }
    .video-note { font-size: .74rem; color: var(--muted); }
    .video-strip-head { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-top: 1.35rem; flex-wrap: wrap; }
    .video-strip-title { font-family: 'Cinzel', serif; font-size: .92rem; color: var(--white); }
    .video-strip-count { font-size: .72rem; color: var(--muted); }
    .video-strip { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: .85rem; margin-top: .85rem; }
    .video-card { background: rgba(255,255,255,.03); border: 1px solid var(--glass-b); border-radius: 6px; overflow: hidden; text-align: left; cursor: pointer; transition: .25s ease; padding: 0; appearance: none; -webkit-appearance: none; }
    .video-card:hover, .video-card.active { transform: translateY(-3px); border-color: var(--gold-dim); }
    .video-card-thumb { position: relative; aspect-ratio: 16/9; background: rgba(0,0,0,.45); overflow: hidden; }
    .video-card-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .video-card-badge { position: absolute; left: .6rem; top: .6rem; background: rgba(7,5,30,.82); border: 1px solid rgba(201,169,110,.25); color: var(--gold); border-radius: 999px; padding: .25rem .5rem; font-size: .58rem; letter-spacing: .12em; text-transform: uppercase; }
    .video-card-body { padding: .8rem; }
    .video-card-title { font-size: .8rem; color: var(--white); line-height: 1.45; min-height: 3.1em; }
    .video-card-meta { margin-top: .45rem; font-size: .68rem; color: var(--muted); }
    .video-empty { margin-top: 1rem; padding: 1.25rem; text-align: center; color: var(--muted); border: 1px dashed var(--glass-b); border-radius: 6px; }

    /* ── EN VIVO ── */

    /* ── EN VIVO ── */
    #envivo { background: var(--navy-deep); }
    .envivo-wrap { text-align: center; max-width: 880px; width: 100%; padding: 2rem 3rem; }
    .live-pill { display: inline-flex; align-items: center; gap: .5rem; background: rgba(220,50,50,.12); border: 1px solid rgba(220,50,50,.35); border-radius: 100px; padding: .35rem .9rem; font-size: .68rem; letter-spacing: .2em; text-transform: uppercase; color: #ff7070; margin-bottom: 1.4rem; }
    .live-dot-r { width: 7px; height: 7px; border-radius: 50%; background: #ff4444; animation: pulse 1.4s ease infinite; }
    .stream-box { margin-top: 1.75rem; border-radius: 5px; overflow: hidden; border: 1px solid var(--glass-b); background: rgba(0,0,0,.38); aspect-ratio: 16/9; max-height: 48vh; display: flex; align-items: center; justify-content: center; }
    .stream-ph { display: flex; flex-direction: column; align-items: center; gap: .9rem; color: var(--muted); }
    .stream-icon { width: 68px; height: 68px; border-radius: 50%; background: rgba(255,255,255,.05); border: 1px solid var(--glass-b); display: flex; align-items: center; justify-content: center; }
    .stream-hint { font-size: .68rem; color: var(--gold); letter-spacing: .14em; text-transform: uppercase; }
    .stream-box iframe { width: 100%; height: 100%; border: none; }
    .next-txt { margin-top: 1.4rem; font-size: .8rem; color: var(--muted); }
    .next-txt strong { color: var(--gold); }

    /* ── GALERÍA ── */
    #galeria { background: var(--navy); }
    .galeria-wrap { text-align: center; max-width: 1080px; width: 100%; padding: 2rem 3rem; }
    .album-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.25rem; margin-top: 2.5rem; }
    .album-card {
      position: relative; cursor: pointer; border-radius: 3px; overflow: hidden;
      border: 1px solid var(--glass-b); aspect-ratio: 4/3;
      transition: border-color .3s, transform .3s;
    }
    .album-card:hover { border-color: var(--gold-dim); transform: translateY(-4px); }
    .album-card:hover .album-overlay { opacity: 1; }
    .album-card:hover .album-cover-img { transform: scale(1.04); }
    .album-cover-img {
      width: 100%; height: 100%; object-fit: cover;
      transition: transform .5s ease;
      display: block;
    }
    .album-cover-ph {
      width: 100%; height: 100%;
      display: flex; align-items: center; justify-content: center;
      transition: transform .5s ease;
    }
    .album-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(7,5,30,.92) 0%, rgba(7,5,30,.25) 60%, transparent 100%);
      display: flex; flex-direction: column; justify-content: flex-end;
      padding: 1.25rem 1rem; opacity: .85; transition: opacity .3s;
    }
    .album-count {
      position: absolute; top: .75rem; right: .75rem;
      font-size: .58rem; letter-spacing: .18em; text-transform: uppercase;
      color: var(--navy); background: var(--gold); padding: .2rem .55rem; border-radius: 2px;
    }
    .album-name { font-family: 'Cinzel', serif; font-size: .88rem; font-weight: 600; color: var(--white); line-height: 1.3; }
    .album-date { font-size: .65rem; letter-spacing: .16em; text-transform: uppercase; color: var(--gold); margin-top: .3rem; }

    /* Lightbox */
    .lightbox {
      position: fixed; inset: 0; z-index: 300;
      background: rgba(7,5,30,.97); backdrop-filter: blur(16px);
      display: none; flex-direction: column;
      overflow-y: auto;
    }
    .lightbox.open { display: flex; }
    .lightbox-header {
      position: sticky; top: 0; z-index: 10;
      padding: 1.25rem 2rem; display: flex; align-items: center; justify-content: space-between;
      background: rgba(7,5,30,.8); backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--glass-b);
    }
    .lightbox-title { font-family: 'Cinzel', serif; font-size: 1.1rem; font-weight: 600; }
    .lightbox-date { font-size: .68rem; letter-spacing: .18em; text-transform: uppercase; color: var(--gold); margin-top: .2rem; }
    .lightbox-close {
      width: 38px; height: 38px; border-radius: 50%; border: 1px solid var(--glass-b);
      background: var(--glass); cursor: pointer; display: flex; align-items: center; justify-content: center;
      color: var(--white); font-size: 1.2rem; transition: background .3s; flex-shrink: 0;
    }
    .lightbox-close:hover { background: var(--gold-dim); }
    .lightbox-grid {
      display: grid; grid-template-columns: repeat(4,1fr); gap: 3px;
      padding: 1.5rem 2rem 3rem;
      max-width: 1100px; width: 100%; margin: 0 auto;
    }
    .lightbox-photo {
      aspect-ratio: 1; background: var(--glass); border: 1px solid var(--glass-b);
      display: flex; align-items: center; justify-content: center;
      overflow: hidden; cursor: pointer; transition: opacity .3s;
    }
    .lightbox-photo:hover { opacity: .82; }
    .lightbox-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .lightbox-photo-ph {
      width: 100%; height: 100%; display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: .4rem;
      color: rgba(255,255,255,.15); font-size: .58rem; letter-spacing: .12em; text-transform: uppercase;
    }
    .lightbox-photo-ph svg { opacity: .2; }
    .lightbox-empty {
      grid-column: 1/-1; text-align: center; padding: 3rem 1rem;
      color: var(--muted); font-size: .84rem; line-height: 1.8;
    }
    .lightbox-empty span { color: var(--gold); }
    .lb-upload-hint {
      margin-top: 1.25rem; display: inline-flex; align-items: center; gap: .5rem;
      border: 1px dashed rgba(201,169,110,.35); padding: .65rem 1.25rem; border-radius: 3px;
      font-size: .72rem; letter-spacing: .12em; text-transform: uppercase; color: var(--gold);
    }

    /* ── AVISOS ── */
    #avisos { background: linear-gradient(140deg, var(--navy-deep) 0%, var(--navy) 100%); }
    .avisos-wrap { text-align: center; max-width: 880px; width: 100%; padding: 2rem 3rem; }
    .aviso-list { display: flex; flex-direction: column; gap: .85rem; margin-top: 2rem; text-align: left; }
    .aviso-card {
      background: var(--glass); border: 1px solid var(--glass-b); border-radius: 3px;
      padding: 1.25rem 1.5rem; display: flex; align-items: flex-start; gap: 1.25rem;
      transition: border-color .3s;
    }
    .aviso-card:hover { border-color: var(--gold-dim); }
    .aviso-card.urgente { border-left: 3px solid #ff7070; }
    .aviso-card.info { border-left: 3px solid var(--gold); }
    .aviso-card.normal { border-left: 3px solid rgba(255,255,255,.18); }
    .aviso-ico {
      width: 36px; height: 36px; flex-shrink: 0; border-radius: 3px;
      display: flex; align-items: center; justify-content: center;
    }
    .aviso-ico.urgente { background: rgba(255,112,112,.1); }
    .aviso-ico.info { background: var(--gold-dim); }
    .aviso-ico.normal { background: var(--glass); }
    .aviso-tag { font-size: .58rem; letter-spacing: .2em; text-transform: uppercase; padding: .18rem .55rem; border-radius: 2px; font-weight: 600; }
    .aviso-tag.urgente { color: #ff7070; background: rgba(255,112,112,.1); }
    .aviso-tag.info { color: var(--gold); background: var(--gold-dim); }
    .aviso-tag.normal { color: var(--muted); background: var(--glass); }
    .aviso-body { flex: 1; }
    .aviso-titulo { font-family: 'Cinzel', serif; font-size: .92rem; font-weight: 600; margin-bottom: .35rem; }
    .aviso-texto { font-size: .82rem; color: var(--muted); line-height: 1.65; }
    .aviso-footer { display: flex; align-items: center; gap: .75rem; margin-top: .6rem; }
    .aviso-fecha { font-size: .62rem; letter-spacing: .14em; color: var(--muted); text-transform: uppercase; }

    /* ── EVENTOS ── */
    #eventos { background: var(--navy-deep); }
    .eventos-wrap { text-align: center; max-width: 1080px; width: 100%; padding: 2rem 3rem; }
    .evento-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.25rem; margin-top: 2.5rem; }
    .evento-card {
      background: var(--glass); border: 1px solid var(--glass-b); border-radius: 3px;
      padding: 0; overflow: hidden; transition: border-color .3s, transform .3s; text-align: left;
    }
    .evento-card:hover { border-color: var(--gold-dim); transform: translateY(-4px); }
    .evento-date-bar {
      background: linear-gradient(90deg, rgba(201,169,110,.15), transparent);
      border-bottom: 1px solid var(--glass-b);
      padding: .75rem 1.25rem; display: flex; align-items: center; gap: .75rem;
    }
    .evento-dia { font-family: 'Cinzel', serif; font-size: 1.8rem; font-weight: 700; color: var(--gold); line-height: 1; }
    .evento-mes-hora { display: flex; flex-direction: column; }
    .evento-mes { font-size: .62rem; letter-spacing: .22em; text-transform: uppercase; color: var(--gold); }
    .evento-hora { font-size: .72rem; color: var(--muted); margin-top: .15rem; }
    .evento-body { padding: 1.1rem 1.25rem 1.4rem; }
    .evento-tag { font-size: .58rem; letter-spacing: .18em; text-transform: uppercase; color: var(--navy); background: var(--gold); padding: .18rem .55rem; border-radius: 2px; display: inline-block; margin-bottom: .6rem; }
    .evento-titulo { font-family: 'Cinzel', serif; font-size: 1rem; font-weight: 600; line-height: 1.3; }
    .evento-desc { font-size: .78rem; color: var(--muted); margin-top: .55rem; line-height: 1.65; }
    .evento-lugar { display: flex; align-items: center; gap: .4rem; font-size: .68rem; color: var(--muted); margin-top: .75rem; }
    .evento-lugar svg { flex-shrink: 0; }

    /* ── BLOG ── */
    #blog { background: var(--navy); }
    .blog-wrap { text-align: center; max-width: 1080px; width: 100%; padding: 2rem 3rem; }
    .blog-grid { display: grid; grid-template-columns: 1.6fr 1fr; gap: 1.25rem; margin-top: 2.5rem; }
    .blog-card {
      background: var(--glass); border: 1px solid var(--glass-b); border-radius: 3px;
      overflow: hidden; transition: border-color .3s, transform .3s; text-align: left; cursor: pointer;
    }
    .blog-card:hover { border-color: var(--gold-dim); transform: translateY(-4px); }
    .blog-cover {
      width: 100%; aspect-ratio: 16/7; display: flex; align-items: center; justify-content: center;
      position: relative; overflow: hidden;
    }
    .blog-cover-ph {
      width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;
    }
    .blog-cover img { width: 100%; height: 100%; object-fit: cover; }
    .blog-card-body { padding: 1.25rem 1.4rem 1.5rem; }
    .blog-cat { font-size: .6rem; letter-spacing: .22em; text-transform: uppercase; color: var(--gold); }
    .blog-titulo { font-family: 'Cinzel', serif; font-size: 1rem; font-weight: 600; line-height: 1.35; margin-top: .45rem; }
    .blog-excerpt { font-size: .78rem; color: var(--muted); margin-top: .55rem; line-height: 1.7; }
    .blog-meta { display: flex; align-items: center; gap: .5rem; margin-top: .85rem; font-size: .62rem; color: var(--muted); }
    .blog-meta-dot { width: 3px; height: 3px; border-radius: 50%; background: var(--muted); }
    .blog-side { display: flex; flex-direction: column; gap: 1.25rem; }
    .blog-card-sm {
      background: var(--glass); border: 1px solid var(--glass-b); border-radius: 3px;
      display: flex; gap: .9rem; padding: .9rem; overflow: hidden;
      transition: border-color .3s; cursor: pointer; text-align: left; flex: 1;
    }
    .blog-card-sm:hover { border-color: var(--gold-dim); }
    .blog-thumb-sm {
      width: 72px; flex-shrink: 0; border-radius: 2px; overflow: hidden;
      display: flex; align-items: center; justify-content: center;
    }
    .blog-thumb-sm img { width: 100%; height: 100%; object-fit: cover; }
    .blog-thumb-ph { width: 72px; aspect-ratio: 1; flex-shrink: 0; border-radius: 2px; overflow: hidden; }
    .blog-sm-body { flex: 1; min-width: 0; }
    .blog-sm-titulo { font-family: 'Cinzel', serif; font-size: .8rem; font-weight: 600; line-height: 1.35; }
    .blog-sm-meta { font-size: .62rem; color: var(--muted); margin-top: .4rem; }

    /* ── CONTACTO ── */
    #contacto { background: linear-gradient(140deg, var(--navy-deep) 0%, var(--navy) 100%); }
    .cont-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; padding: 2rem 6rem; max-width: 1100px; width: 100%; }
    .cont-items { display: flex; flex-direction: column; gap: 1.5rem; }
    .cont-item { display: flex; align-items: flex-start; gap: 1.1rem; }
    .cont-ico { width: 40px; height: 40px; flex-shrink: 0; border-radius: 3px; background: var(--gold-dim); border: 1px solid rgba(201,169,110,.4); display: flex; align-items: center; justify-content: center; }
    .cont-ico svg { fill: var(--gold); }
    .cont-lbl { font-size: .62rem; letter-spacing: .2em; text-transform: uppercase; color: var(--gold); }
    .cont-val { font-size: .88rem; color: var(--muted); margin-top: .22rem; line-height: 1.55; }
    .social-row { display: flex; gap: .6rem; margin-top: .35rem; }
    .soc-btn { width: 36px; height: 36px; border-radius: 50%; background: var(--glass); border: 1px solid var(--glass-b); display: flex; align-items: center; justify-content: center; cursor: pointer; text-decoration: none; transition: background .3s, border-color .3s; }
    .soc-btn:hover { background: var(--gold-dim); border-color: var(--gold); }
    .soc-btn svg { fill: var(--white); }
    .cont-map { border-radius: 5px; overflow: hidden; border: 1px solid var(--glass-b); background: rgba(0,0,0,.28); min-height: 260px; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: .65rem; color: var(--muted); font-size: .78rem; }
    .cont-map iframe { width: 100%; height: 100%; border: none; }

    /* ── OFRENDAR ── */
    #ofrendar { background: linear-gradient(140deg, var(--navy-deep) 0%, var(--navy-light) 100%); }
    .ofr-wrap { text-align: center; max-width: 680px; width: 100%; padding: 2rem 3rem; }
    .ofr-verse { font-style: italic; font-size: .84rem; color: var(--muted); max-width: 420px; margin: 0 auto; line-height: 1.85; }
    .ofr-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-top: 2.25rem; }
    .ofr-card { background: var(--glass); border: 1px solid var(--glass-b); border-radius: 3px; padding: 1.75rem 1.4rem; transition: border-color .3s; }
    .ofr-card:hover { border-color: var(--gold-dim); }
    .ofr-card-title { font-family: 'Cinzel', serif; font-size: .95rem; color: var(--gold); margin-bottom: .9rem; }
    .ofr-detail { font-size: .8rem; color: var(--muted); line-height: 2; }
    .ofr-detail strong { color: var(--white); }
    .qr-ph { width: 96px; height: 96px; margin: 0 auto 1rem; background: rgba(255,255,255,.07); border: 1px dashed rgba(201,169,110,.3); border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: .65rem; color: var(--muted); text-transform: uppercase; letter-spacing: .1em; }
    .ofr-footnote { font-size: .72rem; color: var(--muted); margin-top: 1.75rem; }

    /* ── KEYFRAMES ── */
    @keyframes fadeDown  { from{opacity:0;transform:translateY(-22px)} to{opacity:1;transform:translateY(0)} }
    @keyframes fadeUp    { from{opacity:0;transform:translateY(22px)}  to{opacity:1;transform:translateY(0)} }
    @keyframes cueBounce { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(9px)} }
    @keyframes pulse     { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.45;transform:scale(.68)} }
    @keyframes spin      { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }

    /* ── MOBILE ── */
    @media (max-width: 900px) {
      html, body { overflow: hidden; }

.scroll-wrap {
  height: 100dvh;
  min-height: 100dvh;
  overflow-y: auto;
  scroll-snap-type: y mandatory;
  -webkit-overflow-scrolling: touch;
}

.page {
  min-height: 100dvh;
  height: auto;
  overflow: visible;
  justify-content: flex-start;
  padding: 5.5rem 0 2.5rem;
}
      .page-num { display: none; }
