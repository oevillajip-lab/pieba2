<script>
/* ── CANVAS STARS ── */
const canvas = document.getElementById('starCanvas');
const ctx = canvas.getContext('2d');
function resize() { canvas.width = canvas.offsetWidth; canvas.height = canvas.offsetHeight; }
resize();
window.addEventListener('resize', resize);
const stars = Array.from({ length: 140 }, () => ({
  x: Math.random(), y: Math.random(),
  r: Math.random() * 1.4 + 0.25,
  vy: Math.random() * 0.00012 + 0.00004,
  phase: Math.random() * Math.PI * 2,
  base: Math.random() * 0.55 + 0.1
}));
(function loop() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  stars.forEach(s => {
    s.phase += 0.018;
    const a = s.base * (0.55 + 0.45 * Math.sin(s.phase));
    ctx.beginPath();
    ctx.arc(s.x * canvas.width, s.y * canvas.height, s.r, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(201,169,110,${a})`;
    ctx.fill();
    s.y -= s.vy;
    if (s.y < 0) { s.y = 1.02; s.x = Math.random(); }
  });
  requestAnimationFrame(loop);
})();

/* ── NAV / SCROLL ── */
const wrap            = document.getElementById('scrollWrap');
const topnav          = document.getElementById('topnav');
const dots            = document.querySelectorAll('.dot');
const navLinks        = document.querySelectorAll('.nav-links a');
const mobileNavLinks  = document.querySelectorAll('.mobile-nav a[data-section]');

function goTo(id) {
  const el = document.getElementById(id);
  if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function setActive(id) {
  dots.forEach(d => d.classList.toggle('active', d.dataset.t === id));
  navLinks.forEach(a => a.classList.toggle('active', a.dataset.section === id));
  mobileNavLinks.forEach(a => a.classList.toggle('active', a.dataset.section === id));
}

const scrollEl = wrap;
scrollEl.addEventListener('scroll', () => {
  const st = scrollEl.scrollTop;
  topnav.classList.toggle('scrolled', st > 60);
});

const io = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      setActive(e.target.id);
      e.target.querySelectorAll('.reveal').forEach(el => el.classList.add('visible'));
    }
  });
}, { root: wrap, threshold: 0.35 });

document.querySelectorAll('.page').forEach(s => io.observe(s));
document.querySelectorAll('#inicio .reveal').forEach(el => el.classList.add('visible'));

function toggleNav() {
  document.getElementById('ham').classList.toggle('open');
  document.getElementById('mobileNav').classList.toggle('open');
}

function closeNav() {
  document.getElementById('ham').classList.remove('open');
  document.getElementById('mobileNav').classList.remove('open');
}

/* ── LIGHTBOX ── */
function openAlbum(name, date, photoCount) {
  document.getElementById('lbTitle').textContent = name;
  document.getElementById('lbDate').textContent = date;
  const grid = document.getElementById('lbGrid');
  grid.innerHTML = '';

  if (photoCount === 0) {
    grid.innerHTML = `
      <div class="lightbox-empty">
        <p>Este álbum aún no tiene fotos.</p>
        <p style="margin-top:.5rem;font-size:.75rem;">Cuando integres Sanity CMS, las fotos aparecerán aquí automáticamente.</p>
        <div class="lb-upload-hint">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          Agregar fotos desde el panel CMS
        </div>
      </div>`;
  } else {
    for (let i = 0; i < photoCount; i++) {
      grid.innerHTML += `<div class="lightbox-photo"><div class="lightbox-photo-ph"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div></div>`;
    }
  }

  document.getElementById('lightbox').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeLightbox() {
  document.getElementById('lightbox').classList.remove('open');
  document.body.style.overflow = '';
}

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') closeLightbox();
});
</script>

<script>
/* ── YOUTUBE ── */
const YT_API_KEY    = 'AIzaSyAgz1KXOuS4q-uxNKL9GJdRQJ4P1jGrDG4';
const YT_CHANNEL_ID = 'UCcijrVl3zWSXSuzP3nQI32A';
const YT_BASE       = 'https://www.googleapis.com/youtube/v3';
const ytOK = () => Boolean(YT_API_KEY && YT_CHANNEL_ID);
const qs = s => document.querySelector(s);

async function ytFetch(path, params = {}) {
  const url = new URL(`${YT_BASE}/${path}`);
  Object.entries({ ...params, key: YT_API_KEY }).forEach(([k, v]) => {
    if (v !== undefined && v !== null && v !== '') url.searchParams.set(k, v);
  });
  const res = await fetch(url);
  const data = await res.json();
  if (!res.ok) throw new Error(data.error?.message || 'Error YouTube');
  return data;
}

function fmtDate(iso) {
  return new Date(iso).toLocaleDateString('es-PY', { day: 'numeric', month: 'long', year: 'numeric' });
}
function fmtDateTime(iso) {
  return new Date(iso).toLocaleString('es-PY', { weekday: 'long', day: 'numeric', month: 'long', hour: '2-digit', minute: '2-digit' });
}
function openVideo(videoId) { window.open(`https://youtube.com/watch?v=${videoId}`, '_blank'); }
function closeSermonPlayer() {
  const w = document.getElementById('sermonPlayerWrap');
  const f = document.getElementById('sermonPlayer');
  if (f) f.src = '';
  if (w) w.style.display = 'none';
}

async function getUploadsPlaylistId() {
  const data = await ytFetch('channels', { part: 'contentDetails', id: YT_CHANNEL_ID });
  return data.items?.[0]?.contentDetails?.relatedPlaylists?.uploads || null;
}

async function getLatestUpload() {
  const uploadsId = await getUploadsPlaylistId();
  if (!uploadsId) return null;
  const data = await ytFetch('playlistItems', { part: 'snippet', playlistId: uploadsId, maxResults: 1 });
  const item = data.items?.[0];
  if (!item?.snippet?.resourceId?.videoId) return null;
  return {
    videoId: item.snippet.resourceId.videoId,
    title: item.snippet.title,
    publishedAt: item.snippet.publishedAt,
    thumb: item.snippet.thumbnails?.high?.url || item.snippet.thumbnails?.medium?.url || item.snippet.thumbnails?.default?.url
  };
}

async function getBroadcast(eventType) {
  const search = await ytFetch('search', { part: 'snippet', channelId: YT_CHANNEL_ID, eventType, type: 'video', videoEmbeddable: 'true', maxResults: 5 });
  const ids = (search.items || []).map(i => i.id?.videoId).filter(Boolean);
  if (!ids.length) return null;
  const videos = await ytFetch('videos', { part: 'snippet,liveStreamingDetails', id: ids.join(',') });
  const items = (videos.items || []).map(v => ({
    videoId: v.id, title: v.snippet?.title || '',
    thumb: v.snippet?.thumbnails?.high?.url || v.snippet?.thumbnails?.medium?.url || v.snippet?.thumbnails?.default?.url,
    publishedAt: v.snippet?.publishedAt || null,
    scheduledStartTime: v.liveStreamingDetails?.scheduledStartTime || null,
    actualStartTime: v.liveStreamingDetails?.actualStartTime || null
  }));
  if (!items.length) return null;
  if (eventType === 'live') items.sort((a,b) => new Date(b.actualStartTime||b.publishedAt) - new Date(a.actualStartTime||a.publishedAt));
  else items.sort((a,b) => new Date(a.scheduledStartTime||a.publishedAt) - new Date(b.scheduledStartTime||b.publishedAt));
  return items[0];
}

function renderLatestCulto(video) {
  if (!video) return;
  const title = qs('.sermon-title'), meta = qs('.sermon-meta'), row = qs('.sermon-row');
  if (title) title.textContent = video.title.length > 70 ? video.title.slice(0,67)+'…' : video.title;
  if (meta) meta.textContent = `YouTube · ${fmtDate(video.publishedAt)} · Último culto publicado`;
  if (row) {
    row.style.cursor = 'pointer';
    row.onclick = () => {
      const w = document.getElementById('sermonPlayerWrap');
      const f = document.getElementById('sermonPlayer');
      if (!w || !f) return;
      const embedUrl = `https://www.youtube.com/embed/${video.videoId}?autoplay=1&rel=0&playsinline=1&controls=1`;
      if (w.style.display !== 'none' && f.src.includes(video.videoId)) { closeSermonPlayer(); return; }
      f.src = embedUrl; w.style.display = 'block'; w.classList.add('visible');
      w.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    };
  }
}

function renderLive(video) {
  const box = qs('.stream-box'), pill = qs('.live-pill'), next = qs('.next-txt');
  if (!box || !video) return;
  box.innerHTML = `<iframe src="https://www.youtube.com/embed/${video.videoId}?autoplay=1&controls=1&rel=0&playsinline=1" allowfullscreen allow="autoplay;encrypted-media;picture-in-picture" style="width:100%;height:100%;border:none"></iframe>`;
  if (pill) pill.innerHTML = '<span class="live-dot-r"></span>EN VIVO AHORA';
  if (next) next.innerHTML = `📺 <strong>${video.title}</strong> · Transmisión en curso`;
}

function renderUpcoming(video) {
  const box = qs('.stream-box'), next = qs('.next-txt'), pill = qs('.live-pill');
  if (!box || !video) return;
  box.innerHTML = `<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;padding:1.25rem"><div style="max-width:520px;width:100%;text-align:center">${video.thumb?`<img src="${video.thumb}" alt="" style="width:100%;aspect-ratio:16/9;object-fit:cover;border-radius:4px;border:1px solid rgba(255,255,255,.08);margin-bottom:1rem">`:''}<p style="font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:var(--gold);margin-bottom:.65rem">Próxima transmisión programada</p><p style="font-size:.95rem;line-height:1.5;color:var(--white);margin-bottom:.85rem">${video.title}</p><p style="font-size:.82rem;color:var(--muted);margin-bottom:1rem">${video.scheduledStartTime?fmtDateTime(video.scheduledStartTime):'Horario pendiente'}</p><button type="button" onclick="openVideo('${video.videoId}')" style="background:var(--gold);color:#0f0b32;border:none;padding:.6rem 1.3rem;border-radius:2px;font-size:.72rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;cursor:pointer">Ver en YouTube</button></div></div>`;
  if (pill) pill.innerHTML = '<span class="live-dot-r"></span>PRÓXIMO EN VIVO';
  if (next) next.innerHTML = `Próxima transmisión: <strong>${video.scheduledStartTime?fmtDateTime(video.scheduledStartTime):'Programada'}</strong>`;
}

function renderLastServiceFallback(video) {
  const box = qs('.stream-box'), next = qs('.next-txt'), pill = qs('.live-pill');
  if (!box || !video) return;
  box.innerHTML = `<div class="stream-ph"><div class="stream-icon"><svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.35)" stroke-width="1.5"><polygon points="5 3 19 12 5 21 5 3"/></svg></div><p style="font-size:.84rem;">No hay transmisión en vivo activa<br>ni programada en este momento</p><button type="button" onclick="openVideo('${video.videoId}')" style="background:var(--gold);color:#0f0b32;border:none;padding:.6rem 1.3rem;border-radius:2px;font-size:.72rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;cursor:pointer">▶ Ver último culto</button></div>`;
  if (pill) pill.innerHTML = '<span class="live-dot-r"></span>EN VIVO';
  if (next) next.innerHTML = `Último culto publicado: <strong>${fmtDate(video.publishedAt)}</strong>`;
}

async function initYouTubeSections() {
  if (!ytOK()) return;
  try {
    const latest = await getLatestUpload();
    renderLatestCulto(latest);
    const live = await getBroadcast('live');
    if (live) { renderLive(live); return; }
    const upcoming = await getBroadcast('upcoming');
    if (upcoming) { renderUpcoming(upcoming); return; }
    if (latest) renderLastServiceFallback(latest);
  } catch(e) {
    console.warn('YouTube:', e);
    const title = qs('.sermon-title'), meta = qs('.sermon-meta'), next = qs('.next-txt');
    if (title) title.textContent = 'No se pudo cargar el último culto';
    if (meta) meta.textContent = 'Verificá la API key y el channel ID';
    if (next) next.innerHTML = 'No se pudo consultar el canal';
  }
}

window.addEventListener('DOMContentLoaded', initYouTubeSections);
</script>
</body>
</html>