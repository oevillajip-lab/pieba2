      #inicio { min-height: 100dvh; justify-content: center; padding-top: 5rem; padding-bottom: 2rem; }
      .hero-content { width: 100%; padding: 0 1.2rem; }
      .hero-logo { width: min(55vw, 200px); height: min(55vw, 200px); margin-bottom: 1rem; }
      .hero-name { font-size: clamp(1.1rem, 6vw, 1.8rem); letter-spacing: .06em; max-width: 90%; }
